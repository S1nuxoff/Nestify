<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Backdrop -->
    <ImageView
        android:id="@+id/slide_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="backdrop" />

    <!-- Gradient overlay: dark bottom + left edge -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/featured_slide_gradient" />

    <!-- Content: left bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:orientation="vertical"
        android:padding="56dp"
        android:paddingBottom="72dp">

        <!-- Title -->
        <TextView
            android:id="@+id/slide_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="640dp"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.05"
            android:maxLines="2"
            android:ellipsize="end"
            android:shadowColor="#88000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="8" />

        <!-- Genres -->
        <TextView
            android:id="@+id/slide_genres"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#AAFFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1" />

        <!-- Meta: year · rating -->
        <TextView
            android:id="@+id/slide_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#88FFFFFF"
            android:textSize="15sp" />

    </LinearLayout>

</FrameLayout>
