<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom-to-top dark gradient for featured slide -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#CC0d0d0d"
                android:centerColor="#660d0d0d"
                android:endColor="#000d0d0d"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
