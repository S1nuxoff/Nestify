<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0d0d">

    <!-- ВІДЕОПЛЕЄР ПОЗАДУ -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="true"
        app:show_buffering="when_playing"
        app:controller_layout_id="@layout/player_controller"
        app:show_timeout="4000" />

    <!-- ===== СТАН 1: ВІДКЛЮЧЕНИЙ ===== -->
    <FrameLayout
        android:id="@+id/screen_disconnected"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0d0d0d"
        android:visibility="gone">

        <!-- Центральний контент -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp">

            <ImageView
                android:layout_width="200dp"
                android:layout_height="60dp"
                android:src="@drawable/nestify_logo"
                android:scaleType="fitCenter"
                android:contentDescription="Nestify"
                android:layout_marginBottom="40dp" />

            <TextView
                android:id="@+id/status_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Очікуємо підключення"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/info_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Відкрийте Nestify на телефоні та натисніть «Дивитись на ТВ»"
                android:textSize="16sp"
                android:textColor="#88FFFFFF"
                android:gravity="center"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:layout_marginBottom="32dp" />

            <!-- Кнопка оновити — видима тільки коли нема мережі -->
            <Button
                android:id="@+id/btn_retry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Повторити"
                android:textSize="15sp"
                android:textColor="#0d0d0d"
                android:textStyle="bold"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_btn_white_focusable"
                android:visibility="gone"
                android:focusable="true"
                android:focusableInTouchMode="false" />

        </LinearLayout>

        <!-- Профіль + кнопки — нижній лівий кут -->
        <LinearLayout
            android:id="@+id/disconnected_profile_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:background="@drawable/bg_qr_panel"
            android:visibility="gone">

            <ImageView
                android:id="@+id/disconnected_avatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="Avatar"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/disconnected_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="16dp"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_switch_profile"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Змінити"
                android:textSize="13sp"
                android:textColor="#0d0d0d"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_btn_white_focusable"
                android:layout_marginEnd="8dp"
                android:focusable="true"
                android:focusableInTouchMode="false" />

            <Button
                android:id="@+id/btn_logout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Вийти"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/bg_btn_dark_focusable"
                android:focusable="true"
                android:focusableInTouchMode="false" />

        </LinearLayout>

    </FrameLayout>

    <!-- ===== СТАН 2: ПІДКЛЮЧЕНИЙ — HOME ===== -->
    <FrameLayout
        android:id="@+id/screen_connected"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0d0d0d"
        android:visibility="gone">

        <!-- Main scrollable content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/home_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:focusable="false"
            android:descendantFocusability="afterDescendants">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Featured slider (480dp tall) -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="480dp">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/featured_pager"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:focusable="true"
                        android:focusableInTouchMode="false" />

                    <!-- Dot indicators -->
                    <LinearLayout
                        android:id="@+id/slide_dots"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="14dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:visibility="gone" />

                </FrameLayout>

                <!-- Continue Watching row -->
                <LinearLayout
                    android:id="@+id/continue_row_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="0dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Продовжити перегляд"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:paddingStart="48dp"
                        android:paddingEnd="48dp"
                        android:layout_marginBottom="12dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/continue_recycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="48dp"
                        android:paddingEnd="48dp"
                        android:clipToPadding="false"
                        android:focusable="false"
                        android:descendantFocusability="afterDescendants"
                        android:orientation="horizontal" />

                </LinearLayout>

                <!-- Category selector -->
                <LinearLayout
                    android:id="@+id/category_selector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="48dp"
                    android:paddingEnd="48dp"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="20dp"
                    android:gravity="start"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/cat_all"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Все"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:background="@drawable/bg_cat_btn_selected"
                        android:layout_marginEnd="8dp"
                        android:focusable="true"
                        android:focusableInTouchMode="false" />

                    <Button
                        android:id="@+id/cat_movies"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Фільми"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:background="@drawable/bg_cat_btn"
                        android:layout_marginEnd="8dp"
                        android:focusable="true"
                        android:focusableInTouchMode="false" />

                    <Button
                        android:id="@+id/cat_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Серіали"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:background="@drawable/bg_cat_btn"
                        android:layout_marginEnd="8dp"
                        android:focusable="true"
                        android:focusableInTouchMode="false" />

                    <Button
                        android:id="@+id/cat_animation"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Анімація"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:background="@drawable/bg_cat_btn"
                        android:focusable="true"
                        android:focusableInTouchMode="false" />

                </LinearLayout>

                <!-- Content sections (vertical RecyclerView) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/sections_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:descendantFocusability="afterDescendants"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

                <!-- Content loading spinner -->
                <LinearLayout
                    android:id="@+id/content_loading"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:gravity="center"
                    android:visibility="gone">

                    <ProgressBar
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:indeterminateTint="#FFFFFF" />

                </LinearLayout>

                <!-- Bottom padding -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="48dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Initial full-screen loading (before any data) -->
        <LinearLayout
            android:id="@+id/initial_loading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

            <ImageView
                android:id="@+id/avatar_image"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:contentDescription="Avatar"
                android:scaleType="centerCrop"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/connected_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Профіль"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Підбираємо рекомендації…"
                android:textSize="15sp"
                android:textColor="#88FFFFFF" />
        </LinearLayout>

        <!-- Profile pill: top-left (click to expand) -->
        <LinearLayout
            android:id="@+id/profile_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="28dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@drawable/bg_pill_dark"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/pill_avatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="Avatar"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/pill_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Expanded actions — hidden by default -->
            <LinearLayout
                android:id="@+id/pill_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/pill_btn_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Змінити профіль"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_btn_gray_pill"
                    android:layout_marginEnd="8dp"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:nextFocusRight="@id/pill_btn_logout"
                    android:nextFocusLeft="@id/pill_btn_logout" />

                <Button
                    android:id="@+id/pill_btn_logout"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Вийти"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_btn_red_pill"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:nextFocusRight="@id/pill_btn_switch"
                    android:nextFocusLeft="@id/pill_btn_switch" />

            </LinearLayout>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/movie_details_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC0D0D0D"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="64dp"
                android:paddingEnd="64dp"
                android:paddingTop="52dp"
                android:paddingBottom="52dp">

                <ImageView
                    android:id="@+id/movie_details_poster"
                    android:layout_width="220dp"
                    android:layout_height="330dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Poster" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="36dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/movie_details_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxWidth="760dp"
                        android:textColor="#FFFFFF"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/movie_details_meta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="#CCFFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/movie_details_genres"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="#AAFFFFFF"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/movie_details_overview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:maxWidth="760dp"
                        android:textColor="#E6FFFFFF"
                        android:textSize="18sp"
                        android:lineSpacingExtra="3dp"
                        android:maxLines="6"
                        android:ellipsize="end" />

                    <Button
                        android:id="@+id/movie_details_watch_btn"
                        android:layout_width="220dp"
                        android:layout_height="54dp"
                        android:layout_marginTop="28dp"
                        android:text="Дивитися"
                        android:textSize="16sp"
                        android:textColor="#0d0d0d"
                        android:textStyle="bold"
                        android:background="@drawable/bg_btn_white_focusable"
                        android:focusable="true"
                        android:focusableInTouchMode="false" />

                    <TextView
                        android:id="@+id/movie_details_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="#88FFFFFF"
                        android:textSize="14sp"
                        android:visibility="gone" />

                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/selection_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#D90D0D0D"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="64dp"
                android:paddingEnd="64dp"
                android:paddingTop="48dp"
                android:paddingBottom="48dp">

                <TextView
                    android:id="@+id/selection_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/selection_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="#AAFFFFFF"
                    android:textSize="15sp" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="26dp"
                    android:fadingEdge="none"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/selection_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>
            </LinearLayout>
        </FrameLayout>

    </FrameLayout>

    <!-- ===== СТАН 3: АВТОРИЗАЦІЯ ===== -->
    <include
        android:id="@+id/screen_auth"
        layout="@layout/screen_auth"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- ===== СТАН 4: ВИБІР ПРОФІЛЮ ===== -->
    <include
        android:id="@+id/screen_profile_picker"
        layout="@layout/screen_profile_picker"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- ===== SPLASH ===== -->
    <LinearLayout
        android:id="@+id/splash_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#0d0d0d">

        <ImageView
            android:id="@+id/logo_image"
            android:layout_width="260dp"
            android:layout_height="80dp"
            android:src="@drawable/nestify_logo"
            android:scaleType="fitCenter"
            android:contentDescription="Logo" />
    </LinearLayout>

</FrameLayout>
