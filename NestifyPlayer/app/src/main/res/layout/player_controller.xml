<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom ExoPlayer controller layout.
  ExoPlayer auto-binds views by ID: exo_play_pause, exo_rew, exo_ffwd,
  exo_progress, exo_position, exo_duration.
  player_title / player_subtitle are managed from MainActivity.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── TOP BAR: title + subtitle ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/player_gradient_top"
        android:orientation="vertical"
        android:paddingStart="56dp"
        android:paddingEnd="56dp"
        android:paddingTop="28dp"
        android:paddingBottom="56dp">

        <TextView
            android:id="@+id/player_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/player_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCFFFFFF"
            android:textSize="18sp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ── BOTTOM BAR: progress + buttons ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/player_gradient_bottom"
        android:orientation="vertical"
        android:paddingStart="56dp"
        android:paddingEnd="56dp"
        android:paddingTop="48dp"
        android:paddingBottom="36dp">

        <!-- Progress row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="monospace"
                android:minWidth="80dp" />

            <androidx.media3.ui.DefaultTimeBar
                android:id="@id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:played_color="#FFFFFF"
                app:scrubber_color="#FFFFFF"
                app:scrubber_dragged_size="20dp"
                app:scrubber_enabled_size="14dp"
                app:buffered_color="#55FFFFFF"
                app:unplayed_color="#33FFFFFF"
                app:bar_height="4dp" />

            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAFFFFFF"
                android:textSize="18sp"
                android:fontFamily="monospace"
                android:minWidth="80dp"
                android:gravity="end" />

        </LinearLayout>

        <!-- Buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- -15s -->
            <ImageButton
                android:id="@id/exo_rew"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:scaleType="center"
                android:tint="#FFFFFF"
                android:focusable="true"
                android:layout_marginEnd="24dp" />

            <!-- Play / Pause -->
            <ImageButton
                android:id="@id/exo_play_pause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:scaleType="center"
                android:tint="#FFFFFF"
                android:focusable="true" />

            <!-- +15s -->
            <ImageButton
                android:id="@id/exo_ffwd"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:scaleType="center"
                android:tint="#FFFFFF"
                android:focusable="true"
                android:layout_marginStart="24dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
